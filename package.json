{
  "name": "opencode-plugin-kit",
  "version": "0.0.0",
  "description": "Starter kit for building opencode plugins with server + TUI support",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin-template",
    "tui"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.tsx",
      "types": "./dist/tui.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/build-tui.mjs",
    "build:check": "tsc --project tsconfig.build.json --noEmit",
    "dev": "tsc --project tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "dev:install": "node scripts/dev-tui-install.mjs",
    "dev:uninstall": "node scripts/dev-tui-uninstall.mjs",
    "debug": "./scripts/debug.sh",
    "debug:tail": "tail -f opencode-debug.log",
    "prepublishOnly": "pnpm run build:check && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.1.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@opencode-ai/sdk": "^1.17.8",
    "@types/node": "^22.0.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@opentui/core": "^0.3.4",
    "@opentui/keymap": "^0.3.4",
    "@opentui/solid": "^0.3.4",
    "solid-js": "^1.9.0"
  }
}
